<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Flask Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8080/{R:1}" />
        </rule>
      </rules>

      <!-- 외부 URL(accounts.spotify.com 등)로 가는 302 리다이렉트를
           IIS가 내부 경로로 바꾸지 않도록 막음 -->
      <outboundRules>
        <rule name="Allow External Redirects" stopProcessing="true">
          <match serverVariable="RESPONSE_Location"
                 pattern="^https?://" />
          <action type="None" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- ARR이 리다이렉트 응답의 Location 헤더를 덮어쓰지 않도록 -->
    <proxy enabled="true" reverseRewriteHostInResponseHeaders="false" />
  </system.webServer>
</configuration>
